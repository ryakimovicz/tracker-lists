# App configuration
PROJECT_NAME="Pathd"
API_V1_STR="/api/v1"

# Database configuration
# For local development with SQLite, use: sqlite:///./tracker_lists.db
# For PostgreSQL: postgresql://user:password@localhost:5432/pathd
DATABASE_URL="sqlite:///./tracker_lists.db"

# Security
# Run `openssl rand -hex 32` to generate a secure secret key
SECRET_KEY="change_this_to_a_very_secure_secret_key_secret_key_secret_key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# External APIs
COMIC_VINE_API_KEY=""       # https://comicvine.gamespot.com/api/
TMDB_API_KEY=""             # https://www.themoviedb.org/settings/api
GOOGLE_BOOKS_API_KEY=""     # https://console.cloud.google.com/

# IGDB (via Twitch Developer - https://dev.twitch.tv/console/apps)
# Create an app at the link above, set any HTTPS redirect URL (e.g. http://localhost)
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# CORS configuration
BACKEND_CORS_ORIGINS='["http://localhost:5173", "http://127.0.0.1:5173"]'

# Email (optional, for password recovery)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
EMAILS_FROM_EMAIL="noreply@pathd.app"
